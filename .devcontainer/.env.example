# Docker Compose プロジェクト名
# この値を変更することで、複数のプロジェクトを同一端末で同時に起動できます
# プロジェクト名はコンテナ名のプレフィックスとして使用されます
# 例: myproject を設定すると、コンテナ名は myproject-app-1, myproject-postgres-1 のようになります
COMPOSE_PROJECT_NAME=python-template

# データベース設定（PostgreSQLを使用する場合のみ）
POSTGRES_DB=dev_db
POSTGRES_USER=dev_user
POSTGRES_PASSWORD=dev_password
